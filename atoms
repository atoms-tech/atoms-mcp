class ServerTarget(str, Enum):
    """Presets for server start targets."""
    LOCAL = "local"
    HTTP = "http"
    
_SCRIPT_DIR = Path(__file__).resolve().parent

def _find_project_root(start: Path) -> Path:
    marker = "fastmcp.json"
    current = start
    for _ in range(6):
        if (current / marker).exists():
            return current
        current = current.parent
    return start

PROJECT_ROOT = _find_project_root(_SCRIPT_DIR)
FASTMCP_CONFIG_PATH = PROJECT_ROOT / "fastmcp.json"
STATE_DIR = Path.home() / ".atoms"
PID_FILE = STATE_DIR / "atoms_server.pid"
LAST_CMD_FILE = STATE_DIR / "atoms_server_command.json"
ENV_EXPORTS = [
    "ATOMS_FASTMCP_TRANSPORT",
    "ATOMS_FASTMCP_HOST",
    "ATOMS_FASTMCP_PORT",
    "ATOMS_FASTMCP_HTTP_PATH",
    "ATOMS_TUNNEL",
    "ATOMS_TELEMETRY",
]
    
    
def _fastmcp_config_path() -> Path:
    if FASTMCP_CONFIG_PATH.exists():
        return FASTMCP_CONFIG_PATH
    cwd_path = Path.cwd() / "fastmcp.json"
    if cwd_path.exists():
        return cwd_path
    raise FileNotFoundError("fastmcp.json not found in project or current directory")


def _ensure_state_dir() -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    
    
def _fastmcp_exec() -> list[str]:
    fastmcp_bin = shutil.which("fastmcp")
    if fastmcp_bin:
        return [fastmcp_bin]
    return [sys.executable, "-m", "fastmcp"]
    
    
def _build_fastmcp_command(
    transport: str,
    host: str,
    port: int,
    path_value: str,
    log_level: str,
    skip_env: bool,
    skip_source: bool,
    project: Optional[Path],
    extra_args: list[str],
) -> list[str]:
    config_path = _fastmcp_config_path()
    cmd = _fastmcp_exec() + ["run", str(config_path)]
    if project:
        cmd += ["--project", str(project)]
    if skip_env:
        cmd.append("--skip-env")
    if skip_source:
        cmd.append("--skip-source")
    if transport:
        cmd += ["--transport", transport]
        if transport == "http":
            cmd += ["--host", host, "--port", str(port), "--path", path_value]
    if log_level:
        cmd += ["--log-level", log_level]
    if extra_args:
        cmd.append("--")
        cmd.extend(extra_args)
    return cmd
    
    
def _write_pid(pid: int) -> None:
    _ensure_state_dir()
    PID_FILE.write_text(str(pid))
    
    
def _read_pid() -> int | None:
    try:
        return int(PID_FILE.read_text().strip())
    except (FileNotFoundError, ValueError):
        return None
    
    
def _remove_pid() -> None:
    PID_FILE.unlink(missing_ok=True)
    
    
def _is_process_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
    except OSError:
        return False
    return True
    
    
def _save_last_command(cmd: list[str], env: dict[str, str], foreground: bool) -> None:
    _ensure_state_dir()
    payload = {
        "cmd": cmd,
        "env": {key: env.get(key, "") for key in ENV_EXPORTS},
        "foreground": foreground,
    }
    LAST_CMD_FILE.write_text(json.dumps(payload, indent=2))
    
    
def _load_last_command() -> dict | None:
    try:
        return json.loads(LAST_CMD_FILE.read_text())
    except (FileNotFoundError, json.JSONDecodeError):
        return None
    
    
def _stop_running_process(graceful: bool, timeout: int) -> bool:
    pid = _read_pid()
    if not pid:
        return False
    if not _is_process_alive(pid):
        _remove_pid()
        return False
    
    signal_to_send = signal.SIGINT if graceful else signal.SIGTERM
    os.kill(pid, signal_to_send)
    start_time = time.time()
    while time.time() - start_time < timeout:
        if not _is_process_alive(pid):
            _remove_pid()
            return True
        time.sleep(0.5)
    
    if hasattr(signal, "SIGKILL"):
        os.kill(pid, signal.SIGKILL)
    _remove_pid()
    return False
    
    
def _format_command(cmd: list[str]) -> str:
    return shlex.join(cmd)
    
    
def _run_foreground(cmd: list[str], env: dict[str, str]) -> int:
    console.print(f"[dim]ℹ Running: {_format_command(cmd)}[/dim]")
    
    # Add current directory to PYTHONPATH to preserve relative imports
    env_with_path = env.copy()
    current_path = str(Path(__file__).parent)
    if "PYTHONPATH" in env_with_path:
        env_with_path["PYTHONPATH"] = f"{current_path}:{env_with_path['PYTHONPATH']}"
    else:
        env_with_path["PYTHONPATH"] = current_path
    
    with subprocess.Popen(
        cmd,
        cwd=PROJECT_ROOT,
        env=env_with_path,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        bufsize=1,
    ) as proc:
        _write_pid(proc.pid)
        try:
            for line in proc.stdout or []:
                console.print(line.rstrip())
        except KeyboardInterrupt:
            console.print("\n[yellow]⚠ Stopping server (Ctrl+C)[/yellow]")
            proc.send_signal(signal.SIGINT)
        finally:
            proc.wait()
            _remove_pid()
            return proc.returncode or 0
    
    
def _run_background(cmd: list[str], env: dict[str, str]) -> int:
    _ensure_state_dir()
    log_path = STATE_DIR / "atoms_server.log"
    
    # Add current directory to PYTHONPATH to preserve relative imports
    env_with_path = env.copy()
    current_path = str(Path(__file__).parent)
    if "PYTHONPATH" in env_with_path:
        env_with_path["PYTHONPATH"] = f"{current_path}:{env_with_path['PYTHONPATH']}"
    else:
        env_with_path["PYTHONPATH"] = current_path
    
    with open(log_path, "a", encoding="utf-8") as log_file:
        proc = subprocess.Popen(
            cmd,
            cwd=PROJECT_ROOT,
            env=env_with_path,
            stdout=log_file,
            stderr=subprocess.STDOUT,
            text=True,
        )
    _write_pid(proc.pid)
    console.print(f"[green]✓ Server running in background (PID {proc.pid})[/green]")
    console.print(f"[dim]ℹ Logs -> {log_path}[/dim]")
    return proc.pid
    
    
@server_app.command()
def start(
    target: ServerTarget = typer.Option(
        ServerTarget.HTTP,
        "--target",
        "-t",
        case_sensitive=False,
        help="local=stdio, http=http transport",
    ),
    transport: Optional[str] = typer.Option(
        None,
        "--transport",
        help="Override FastMCP transport (default derives from target)",
    ),
    host: Optional[str] = typer.Option(None, "--host", help="HTTP host when using http transport"),
    port: int = typer.Option(8000, "--port", "-p", help="HTTP port"),
    path: str = typer.Option("/api/mcp", "--path", help="HTTP path for MCP endpoint"),
    log_level: str = typer.Option("INFO", "--log-level", help="FastMCP log level"),
    skip_env: bool = typer.Option(True, "--skip-env/--env", help="Skip uv environment prep"),
    skip_source: bool = typer.Option(False, "--skip-source", help="Skip source prep"),
    project: Optional[Path] = typer.Option(None, "--project", help="Use a prepared uv project directory"),
    tunnel: bool = typer.Option(True, "--tunnel/--no-tunnel", help="Set ATOMS_TUNNEL"),
    telemetry: bool = typer.Option(True, "--telemetry/--no-telemetry", help="Set ATOMS_TELEMETRY"),
    foreground: bool = typer.Option(True, "--foreground/--background", help="Stream logs in foreground"),
    extra_args: Optional[List[str]] = typer.Argument(
        None,
        metavar="[FASTMCP_ARGS...]",
        help="Additional arguments forwarded to fastmcp run",
    ),
):
    """Start the FastMCP server via fastmcp run fastmcp.json."""
    
    try:
        config_path = _fastmcp_config_path()
    except FileNotFoundError as exc:
        console.print(f"[red]❌ {exc}[/red]")
        raise typer.Exit(1) from exc
    
    running_pid = _read_pid()
    if running_pid and _is_process_alive(running_pid):
        console.print(f"[yellow]⚠ Server already running (PID {running_pid}). Use 'atoms server stop'.[/yellow]")
        raise typer.Exit(1)
    elif running_pid:
        _remove_pid()
    
    resolved_transport = transport or ("http" if target == ServerTarget.HTTP else "stdio")
    resolved_host = host or ("0.0.0.0" if resolved_transport == "http" else "127.0.0.1")
    
    env = os.environ.copy()
    env.update({
        "ATOMS_FASTMCP_TRANSPORT": resolved_transport,
        "ATOMS_FASTMCP_HOST": resolved_host,
        "ATOMS_FASTMCP_PORT": str(port),
        "ATOMS_FASTMCP_HTTP_PATH": path,
        "ATOMS_TUNNEL": "true" if tunnel else "false",
        "ATOMS_TELEMETRY": "true" if telemetry else "false",
    })
    
    cmd = _build_fastmcp_command(
        resolved_transport,
        resolved_host,
        port,
        path,
        log_level,
        skip_env,
        skip_source,
        project,
        extra_args or [],
    )
    
    _save_last_command(cmd, env, foreground)
    console.print(Panel.fit("[bold blue]🚀 Launching FastMCP server[/bold blue]", border_style="green"))
    console.print(f"[blue]Transport:[/blue] {resolved_transport}")
    if resolved_transport == "http":
        console.print(f"[blue]Endpoint:[/blue] http://{resolved_host}:{port}{path}")
    
    if foreground:
        returncode = _run_foreground(cmd, env)
        if returncode != 0:
            raise typer.Exit(returncode)
    else:
        _run_background(cmd, env)
    
    
@server_app.command()
def stop(
    graceful: bool = typer.Option(True, "--graceful/--force", help="Graceful sends SIGINT"),
    timeout: int = typer.Option(30, "--timeout", help="Seconds to wait before force kill"),
):
    """Stop the running FastMCP process."""
    
    if _stop_running_process(graceful, timeout):
        console.print("[green]✓ Server stopped[/green]")
    else:
        console.print("[yellow]ℹ No running server found[/yellow]")
    
    
@server_app.command()
def restart():
    """Restart using the last recorded command."""
    
    _stop_running_process(True, 10)
    payload = _load_last_command()
    if not payload:
        console.print("[red]❌ No previous start command recorded[/red]")
        raise typer.Exit(1)
    
    env = os.environ.copy()
    env.update({k: v for k, v in payload.get("env", {}).items() if v})
    cmd = payload.get("cmd")
    foreground = payload.get("foreground", True)
    if not cmd:
        console.print("[red]❌ Invalid command history[/red]")
        raise typer.Exit(1)
    
    console.print("[blue]↻ Restarting server using last configuration...[/blue]")
    _save_last_command(cmd, env, foreground)
    if foreground:
        rc = _run_foreground(cmd, env)
        if rc != 0:
            raise typer.Exit(rc)
    else:
        _run_background(cmd, env)
    
    
@server_app.command()
def status():
    """Display server status based on PID tracking."""
    
    pid = _read_pid()
    running = pid is not None and _is_process_alive(pid)
    payload = _load_last_command() or {}
    
    status_table = Table(show_header=True, title="Server Status")
    status_table.add_column("Field", style="bold blue")
    status_table.add_column("Value", style="bold green")
    
    status_table.add_row("Running", "Yes" if running else "No")
    status_table.add_row("PID", str(pid) if pid else "-")
    status_table.add_row(
        "Transport",
        payload.get("env", {}).get("ATOMS_FASTMCP_TRANSPORT", "unknown"),
    )
    status_table.add_row(
        "Endpoint",
        (
            f"{payload.get('env', {}).get('ATOMS_FASTMCP_HOST', '-')}:"
            f"{payload.get('env', {}).get('ATOMS_FASTMCP_PORT', '-')}{payload.get('env', {}).get('ATOMS_FASTMCP_HTTP_PATH', '')}"
        ),
    )
    status_table.add_row("Foreground", "Yes" if payload.get("foreground", True) else "No")
    
    console.print(status_table)
    
    if not running and pid:
        console.print("[yellow]⚠ Removing stale PID file[/yellow]")
        _remove_pid()
