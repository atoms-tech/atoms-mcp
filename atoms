@deploy_app.command("pipeline")
def deploy_pipeline(
    target: str = typer.Argument(..., help="Deployment target (dev/staging/prod)"),
    strategy: str = typer.Option("rolling", "--strategy", help="Deployment strategy"),
    auto_approve: bool = typer.Option(False, "--auto-approve", help="Auto-approve"),
    health_check: bool = typer.Option(True, "--health-check", help="Health check")
):
    """Execute deployment pipeline"""
    
    console.print(Panel.fit(
        f"[bold blue]🚀 Deployment Pipeline[/bold blue]",
        border_style="blue"
    ))
    
    console.print(f"[blue]Target: {target}[/blue]")
    console.print(f"[blue]Strategy: {strategy}[/blue]")
    console.print(f"[blue]Health Check: {health_check}[/blue]")
    
    if not auto_approve:
        console.print("[yellow]⚠ Manual approval required[/yellow]")
        if typer.confirm("Proceed with deployment?"):
            console.print("[bold green]✅ Deployment approved[/bold green]")
        else:
            console.print("[bold red]❌ Deployment cancelled[/bold red]")
            return
    
    # Simulate deployment
    with Progress(console=console) as progress:
        task = progress.add_task("Deploying...", total=100)
        
        steps = [
            "Building package",
            "Running tests",
            "Creating deployment",
            "Deploying to target",
            "Running health check"
        ]
        
        for i, step in enumerate(steps):
            progress.update(task, description=step, completed=(i + 1) * 20)
            time.sleep(0.5)
    
    domain_map = {
        "local": "atomcp.kooshapari.com",
        "dev": "devmcp.atoms.tech",
        "staging": "devmcp.atoms.tech",
        "prod": "atomcp.kooshapari.com",
        "production": "atomcp.kooshapari.com",
    }
    normalized_target = target.lower()
    domain = domain_map.get(normalized_target, f"{normalized_target}.atoms.tech")
    console.print(f"[bold green]✅ Deployment to {target} complete[/bold green]")
    console.print(f"[bold green]🌐 URL: https://{domain}[/bold green]")
    
