class ServerTUI:
    """Rich TUI with raw log dump and comprehensive status bar below"""
    
    def __init__(self, console, port, tunnel, health_interval, debug, verbose):
        self.console = console
        self.port = port
        self.tunnel = tunnel
        self.health_interval = health_interval
        self.debug = debug
        self.verbose = verbose
        
        self.health_data = {}
        self.log_messages = []
        self.running = True
        self.live = None
    
    def start(self):
        """Start TUI"""
        self.live = Live(
            self._render_content(),
            console=self.console,
            refresh_per_second=2,
            transient=False
        )
        self.live.start()
    
    def update_health(self, health_data):
        """Update health data"""
        self.health_data = health_data
    
    def update_logs(self, log_messages):
        """Update log messages"""
        self.log_messages = log_messages
    
    def refresh(self):
        """Refresh TUI display"""
        if self.live:
            self.live.update(self._render_content())
    
    def stop(self):
        """Stop TUI"""
        if self.live:
            self.live.stop()
            self.running = False
    
    def _render_content(self):
        """Render only status bar - logs will be printed as raw stdout"""
        # Create comprehensive status bar (fixed at bottom)
        return self._create_comprehensive_status_bar()
    
    def _create_comprehensive_status_bar(self):
        """Create 2x2 status grid with pulsing colored text"""
        # Create 2x2 grid layout for status
        status_grid = Table.grid(padding=1, expand=True)
        status_grid.add_column("server_services", ratio=1)
        status_grid.add_column("tunnel_resources", ratio=1)
        
        # Server + Services (merged - same localhost endpoint)
        server_services_content = (
            f"[bold green]Server + Services[/bold green]\n"
            f"[dim]Localhost Health:[/dim] {self.health_data.get('localhost_health', 'Healthy')}\n"
            f"[dim]Endpoint:[/dim] http://localhost:{self.port}\n"
            f"[dim]Uptime:[/dim] {self.health_data.get('uptime', '0s')}\n"
            f"[dim]Requests:[/dim] {self.health_data.get('requests', '0')}"
        )
        
        # Tunnel + Resources
        tunnel_status = self.health_data.get('tunnel_service_status', 'Unknown')
        tunnel_resources_content = (
            f"[bold yellow]Tunnel + Resources[/bold yellow]\n"
            f"[dim]Tunnel:[/dim] {tunnel_status}\n"
            f"[dim]Fallback TML:[/dim] {self.health_data.get('fallback_tml_status', 'Ready')}\n"
            f"[dim]Daemons:[/dim] {self.health_data.get('daemons_status', 'Running')}\n"
            f"[dim]System:[/dim] {self.health_data.get('cpu', '0%')} CPU, {self.health_data.get('memory', '0MB')} Mem"
        )
        
        status_grid.add_row(
            Panel(server_services_content, box=HEAVY, padding=(0, 1)),
            Panel(tunnel_resources_content, box=HEAVY, padding=(0, 1))
        )
        
        return status_grid
    
