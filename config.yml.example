app:
  debug: false
  environment: development
  name: atoms-mcp-prod
  version: 1.0.0
features:
  enable_debug_mode: false
  enable_metrics: true
  enable_telemetry: true
logging:
  file: null
  format: text
  level: INFO
performance:
  cache_ttl: 3600
  max_concurrent_requests: 100
  rate_limit_rpm: 60
server:
  host: localhost
  port: 8000
  timeout: 30
  workers: 1
