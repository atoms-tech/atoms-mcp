{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "jsx": "preserve",
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["sst.config.ts", ".sst/**/*"],
  "exclude": ["node_modules", "dist", ".sst"]
}

