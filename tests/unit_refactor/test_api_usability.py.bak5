@pytest.mark.usability
class TestDocumentationCompleteness:
    """Test that all public APIs have proper documentation."""

    def test_entity_service_methods_have_docstrings(self):
        """
        Test EntityService methods have docstrings.

        Given: EntityService class
        When: Examining method docstrings
        Then: All public methods are documented
        """
        methods = [
            "create_entity",
            "get_entity",
            "update_entity",
            "delete_entity",
            "list_entities",
            "search_entities",
            "count_entities",
            "archive_entity",
            "restore_entity",
        ]

        for method_name in methods:
            method = getattr(EntityService, method_name)
            assert method.__doc__ is not None, f"{method_name} missing docstring"
            assert len(method.__doc__.strip()) > 20, (
                f"{method_name} docstring too brief"
            )

    def test_relationship_service_methods_have_docstrings(self):
        """
        Test RelationshipService methods have docstrings.

        Given: RelationshipService class
        When: Examining method docstrings
        Then: All public methods are documented
        """
        methods = [
            "add_relationship",
            "remove_relationship",
            "get_relationships",
        ]

        for method_name in methods:
            method = getattr(RelationshipService, method_name)
            assert method.__doc__ is not None, f"{method_name} missing docstring"
            assert len(method.__doc__.strip()) > 20

    def test_docstrings_include_parameters(self):
        """
        Test docstrings document parameters.

        Given: EntityService.create_entity method
        When: Examining docstring
        Then: Parameters are documented
        """
        docstring = EntityService.create_entity.__doc__

        assert "Args:" in docstring or "Parameters:" in docstring
        assert "entity" in docstring
        assert "validate" in docstring

    def test_docstrings_include_return_values(self):
        """
        Test docstrings document return values.

        Given: EntityService methods with return values
        When: Examining docstrings
        Then: Return values are documented
        """
        docstring = EntityService.create_entity.__doc__

        assert "Returns:" in docstring or "Return:" in docstring

    def test_docstrings_include_exceptions(self):
        """
        Test docstrings document raised exceptions.

        Given: EntityService.create_entity method
        When: Examining docstring
        Then: Exceptions are documented
        """
        docstring = EntityService.create_entity.__doc__

        assert "Raises:" in docstring
        assert "ValueError" in docstring or "RepositoryError" in docstring

    def test_command_classes_have_docstrings(self):
        """
        Test command classes are documented.

        Given: Command classes
        When: Examining class docstrings
        Then: Purpose and attributes are documented
        """
        commands = [CreateEntityCommand, UpdateEntityCommand, DeleteEntityCommand]

        for command_class in commands:
            assert command_class.__doc__ is not None
            assert len(command_class.__doc__.strip()) > 20


# =============================================================================
# API CONSISTENCY TESTS
# =============================================================================


@pytest.mark.usability
class TestAPIConsistency:
    """Test API maintains consistent patterns across modules."""

    def test_service_methods_follow_crud_pattern(self):
        """
        Test service methods follow consistent CRUD naming.

        Given: EntityService
        When: Examining method names
        Then: CRUD operations use standard names (create, get, update, delete, list)
        """
        service_methods = [m for m in dir(EntityService) if not m.startswith("_")]

        assert "create_entity" in service_methods
        assert "get_entity" in service_methods
        assert "update_entity" in service_methods
        assert "delete_entity" in service_methods
        assert "list_entities" in service_methods

    def test_query_classes_follow_naming_convention(self):
        """
        Test query classes follow consistent naming.

        Given: Query classes
        When: Examining class names
        Then: All end with 'Query'
        """
        query_classes = [GetEntityQuery, ListEntitiesQuery, SearchEntitiesQuery]

        for query_class in query_classes:
            assert query_class.__name__.endswith("Query")

    def test_command_classes_follow_naming_convention(self):
        """
        Test command classes follow consistent naming.

        Given: Command classes
        When: Examining class names
        Then: All end with 'Command'
        """
        command_classes = [
            CreateEntityCommand,
            UpdateEntityCommand,
            DeleteEntityCommand,
        ]

        for command_class in command_classes:
            assert command_class.__name__.endswith("Command")

    def test_exception_classes_follow_naming_convention(self):
        """
        Test exception classes follow consistent naming.

        Given: Custom exception classes
        When: Examining class names
        Then: All end with 'Error'
        """
        exceptions = [EntityValidationError, EntityNotFoundError]

        for exc_class in exceptions:
            assert exc_class.__name__.endswith("Error")


# =============================================================================
# PARAMETER VALIDATION FEEDBACK TESTS
# =============================================================================


@pytest.mark.usability
class TestParameterValidationFeedback:
    """Test parameter validation provides helpful feedback."""

    def test_create_command_validates_all_fields(self):
        """
        Test CreateEntityCommand validates all required fields.

        Given: Invalid command data
        When: Validating multiple times
        Then: Each validation error is specific to the field
        """
        # Test entity_type validation
        cmd1 = CreateEntityCommand(entity_type="", name="Test")
        with pytest.raises(EntityValidationError) as exc:
            cmd1.validate()
        assert "entity_type" in str(exc.value).lower()

        # Test name validation
        cmd2 = CreateEntityCommand(entity_type="workspace", name="")
        with pytest.raises(EntityValidationError) as exc:
            cmd2.validate()
        assert "name" in str(exc.value).lower()

        # Test name length validation
        cmd3 = CreateEntityCommand(entity_type="workspace", name="X" * 300)
        with pytest.raises(EntityValidationError) as exc:
            cmd3.validate()
        assert "255" in str(exc.value)

    def test_update_command_validates_entity_id(self):
        """
        Test UpdateEntityCommand validates entity_id.

        Given: UpdateEntityCommand
        When: Validating with empty entity_id
        Then: Error clearly indicates entity_id is required
        """
        cmd = UpdateEntityCommand(entity_id="", updates={"name": "Test"})

        with pytest.raises(EntityValidationError) as exc:
            cmd.validate()

        error_msg = str(exc.value).lower()
        assert "entity_id" in error_msg
        assert "empty" in error_msg or "required" in error_msg

    def test_delete_command_validates_entity_id(self):
        """
        Test DeleteEntityCommand validates entity_id.

        Given: DeleteEntityCommand
        When: Validating with empty entity_id
        Then: Error clearly indicates entity_id is required
        """
        cmd = DeleteEntityCommand(entity_id="")

        with pytest.raises(EntityValidationError) as exc:
            cmd.validate()

        error_msg = str(exc.value).lower()
        assert "entity_id" in error_msg


# =============================================================================
# BACKWARDS COMPATIBILITY TESTS
# =============================================================================


@pytest.mark.usability
class TestBackwardsCompatibility:
    """Test API maintains backwards compatibility."""

    def test_optional_parameters_maintain_compatibility(self):
        """
        Test that adding optional parameters doesn't break existing code.

        Given: Service methods with optional parameters
        When: Calling without new optional parameters
        Then: Methods still work correctly
        """
        # This test ensures that existing code continues to work
        # even as new optional parameters are added
        from atoms_mcp.domain.services.entity_service import EntityService

        # Should work with minimal parameters
        sig = inspect.signature(EntityService.__init__)
        required_params = [
            p.name
            for p in sig.parameters.values()
            if p.default == inspect.Parameter.empty and p.name != "self"
        ]

        # Only repository and logger should be required
        assert len(required_params) == 2
        assert "repository" in required_params
        assert "logger" in required_params

    def test_entity_status_enum_values_stable(self):
        """
        Test EntityStatus enum values remain stable.

        Given: EntityStatus enum
        When: Examining enum values
        Then: Core statuses (ACTIVE, ARCHIVED, DELETED) exist
        """
        # These values must remain stable for backwards compatibility
        assert hasattr(EntityStatus, "ACTIVE")
        assert hasattr(EntityStatus, "ARCHIVED")
        assert hasattr(EntityStatus, "DELETED")

        # Values should be consistent
        assert EntityStatus.ACTIVE.value == "active"
        assert EntityStatus.ARCHIVED.value == "archived"
        assert EntityStatus.DELETED.value == "deleted"

    def test_relationship_type_enum_values_stable(self):
        """
        Test RelationType enum values remain stable.

        Given: RelationType enum
        When: Examining enum values
        Then: Core types remain consistent
        """
        # These values must remain stable
        assert hasattr(RelationType, "PARENT_OF")
        assert hasattr(RelationType, "DEPENDS_ON")
        assert hasattr(RelationType, "REFERENCES")

    def test_command_result_structure_stable(self, mock_repository, mock_logger):
        """
        Test command result structure remains consistent.

        Given: Command handler
        When: Executing command
        Then: Result has expected attributes (success, data, message)
        """
        handler = EntityCommandHandler(mock_repository, mock_logger)
        command = CreateEntityCommand(entity_type="workspace", name="Test")

        result = handler.handle_create(command)

        # Result structure must remain stable
        assert hasattr(result, "success")
        assert hasattr(result, "data")
        assert hasattr(result, "message")
        assert isinstance(result.success, bool)
