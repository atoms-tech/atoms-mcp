"""
API usability and accessibility tests for Atoms MCP.

This module validates API design quality including:
- Clear error messages
- Consistent parameter naming
- Sensible defaults
- Type hints availability
- Documentation completeness
- Backwards compatibility

Tests ensure the API is intuitive, well-documented, and user-friendly.
"""

import inspect
import sys
from pathlib import Path
from typing import Any, Dict, List, Optional, get_type_hints
from unittest.mock import Mock

import pytest

# Add src to path
sys.path.insert(0, str(Path(__file__).parent.parent.parent / "src"))

from atoms_mcp.application.commands.entity_commands import (
    CreateEntityCommand,
    DeleteEntityCommand,
    EntityCommandHandler,
    EntityNotFoundError,
    EntityValidationError,
    UpdateEntityCommand,
)
from atoms_mcp.application.queries.entity_queries import (
    EntityQueryHandler,
    GetEntityQuery,
    ListEntitiesQuery,
    SearchEntitiesQuery,
)
from atoms_mcp.domain.models.entity import Entity, EntityStatus, WorkspaceEntity
from atoms_mcp.domain.models.relationship import Relationship, RelationType
from atoms_mcp.domain.services.entity_service import EntityService
from atoms_mcp.domain.services.relationship_service import RelationshipService
# ValidationError is defined in command modules, not infrastructure
# from atoms_mcp.infrastructure.errors.exceptions import ValidationError


# =============================================================================
# ERROR MESSAGE QUALITY TESTS
# =============================================================================


@pytest.mark.usability
class TestErrorMessageQuality:
    """Test that error messages are clear, actionable, and user-friendly."""

    def test_entity_validation_error_clarity(self):
        """
        Test validation errors provide clear messages.

        Given: Invalid command data
        When: Validating the command
        Then: Error message clearly explains what is wrong
        """
        command = CreateEntityCommand(entity_type="", name="Test")

        with pytest.raises(EntityValidationError) as exc_info:
            command.validate()

        error_message = str(exc_info.value)
        assert "entity_type" in error_message.lower()
        assert "required" in error_message.lower()
        # Error should be actionable
        assert len(error_message) > 10

    def test_entity_not_found_error_includes_id(self, mock_repository, mock_logger):
        """
        Test not found errors include entity ID.

        Given: Non-existent entity ID
        When: Attempting to retrieve entity
        Then: Error or response clearly indicates entity was not found
        """
        service = EntityService(mock_repository, mock_logger)
        entity_id = "nonexistent_id_12345"

        result = service.get_entity(entity_id)

        # Should return None and log warning with ID
        assert result is None
        warnings = mock_logger.get_logs("WARNING")
        assert len(warnings) > 0
        assert entity_id in warnings[0]["message"]

    def test_empty_name_validation_error(self):
        """
        Test empty name validation provides helpful message.

        Given: Command with empty name
        When: Validating the command
        Then: Error explains name is required
        """
        command = CreateEntityCommand(entity_type="workspace", name="")

        with pytest.raises(EntityValidationError) as exc_info:
            command.validate()

        error_message = str(exc_info.value)
        assert "name" in error_message.lower()
        assert "required" in error_message.lower()

    def test_name_length_validation_error(self):
        """
        Test name length validation provides specific guidance.

        Given: Command with overly long name
        When: Validating the command
        Then: Error specifies maximum length allowed
        """
        long_name = "X" * 300
        command = CreateEntityCommand(entity_type="workspace", name=long_name)

        with pytest.raises(EntityValidationError) as exc_info:
            command.validate()

        error_message = str(exc_info.value)
        assert "name" in error_message.lower()
        assert "255" in error_message  # Specifies max length

    def test_invalid_field_update_warning(self, mock_repository, mock_logger):
        """
        Test updating invalid field generates clear warning.

        Given: Update with non-existent field
        When: Attempting to update entity
        Then: Warning clearly indicates field doesn't exist
        """
        service = EntityService(mock_repository, mock_logger)
        entity = WorkspaceEntity(name="Test")
        mock_repository.add_entity(entity)

        service.update_entity(entity.id, {"nonexistent_field": "value"})

        warnings = mock_logger.get_logs("WARNING")
        assert any("does not exist" in w["message"] for w in warnings)
        assert any("nonexistent_field" in w["message"] for w in warnings)

    def test_relationship_cycle_error_message(self, mock_repository, mock_logger):
        """
        Test cycle detection provides informative error.

        Given: Relationship service
        When: Attempting to create circular relationship
        Then: Error explains that cycles are not allowed
        """
        # This test validates that IF cycle detection is implemented,
        # the error message is clear
        service = RelationshipService(mock_repository, mock_logger)

        # Note: Actual cycle detection may not be fully implemented
        # This tests the error message quality if it is raised
        try:
            # Attempt to create a relationship that would cycle
            service.add_relationship(
                source_id="entity_1",
                target_id="entity_1",  # Self-reference
                relationship_type=RelationType.PARENT_CHILD,
            )
        except ValueError as e:
            # If error is raised, it should be clear
            error_message = str(e)
            assert len(error_message) > 10
            assert "cycle" in error_message.lower() or "circular" in error_message.lower()


# =============================================================================
# PARAMETER NAMING CONSISTENCY TESTS
# =============================================================================


@pytest.mark.usability
class TestParameterNamingConsistency:
    """Test that parameters are named consistently across the API."""

    def test_entity_id_parameter_consistency(self):
        """
        Test entity ID parameters use consistent naming.

        Given: Multiple methods that accept entity IDs
        When: Examining parameter names
        Then: All use 'entity_id' consistently
        """
        # Check EntityService methods
        get_sig = inspect.signature(EntityService.get_entity)
        update_sig = inspect.signature(EntityService.update_entity)
        delete_sig = inspect.signature(EntityService.delete_entity)
        archive_sig = inspect.signature(EntityService.archive_entity)
        restore_sig = inspect.signature(EntityService.restore_entity)

        assert "entity_id" in get_sig.parameters
        assert "entity_id" in update_sig.parameters
        assert "entity_id" in delete_sig.parameters
        assert "entity_id" in archive_sig.parameters
        assert "entity_id" in restore_sig.parameters

    def test_filters_parameter_consistency(self):
        """
        Test filter parameters use consistent naming and type.

        Given: Methods that accept filters
        When: Examining parameter names and types
        Then: All use 'filters' with dict type
        """
        list_sig = inspect.signature(EntityService.list_entities)
        count_sig = inspect.signature(EntityService.count_entities)

        assert "filters" in list_sig.parameters
        assert "filters" in count_sig.parameters

        # Check type hints
        list_hints = get_type_hints(EntityService.list_entities)
        count_hints = get_type_hints(EntityService.count_entities)

        # Both should accept Optional[dict]
        assert list_hints.get("filters") is not None
        assert count_hints.get("filters") is not None

    def test_pagination_parameter_consistency(self):
        """
        Test pagination parameters use consistent names.

        Given: Methods with pagination
        When: Examining parameter names
        Then: All use 'limit' and 'offset'
        """
        list_sig = inspect.signature(EntityService.list_entities)
        search_sig = inspect.signature(EntityService.search_entities)

        assert "limit" in list_sig.parameters
        assert "offset" in list_sig.parameters
        assert "limit" in search_sig.parameters

    def test_relationship_parameter_naming(self):
        """
        Test relationship methods use consistent parameter names.

        Given: Relationship service methods
        When: Examining parameter names
        Then: Consistent use of source_id, target_id, relationship_type
        """
        add_sig = inspect.signature(RelationshipService.add_relationship)
        get_sig = inspect.signature(RelationshipService.get_relationships)

        # Core parameters should be consistently named
        assert "source_id" in add_sig.parameters
        assert "target_id" in add_sig.parameters
        assert "relationship_type" in add_sig.parameters

        assert "source_id" in get_sig.parameters
        assert "target_id" in get_sig.parameters
        assert "relationship_type" in get_sig.parameters


# =============================================================================
# SENSIBLE DEFAULTS TESTS
# =============================================================================


@pytest.mark.usability
class TestSensibleDefaults:
    """Test that methods have reasonable default parameter values."""

    def test_entity_creation_validation_default(self):
        """
        Test entity creation defaults to validation enabled.

        Given: EntityService.create_entity method
        When: Not specifying validate parameter
        Then: Defaults to True (validate by default)
        """
        sig = inspect.signature(EntityService.create_entity)
        validate_param = sig.parameters["validate"]

        assert validate_param.default is True

    def test_entity_deletion_soft_delete_default(self):
        """
        Test entity deletion defaults to soft delete.

        Given: EntityService.delete_entity method
        When: Not specifying soft_delete parameter
        Then: Defaults to True (soft delete by default)
        """
        sig = inspect.signature(EntityService.delete_entity)
        soft_delete_param = sig.parameters["soft_delete"]

        assert soft_delete_param.default is True

    def test_cache_usage_default(self):
        """
        Test get_entity defaults to using cache.

        Given: EntityService.get_entity method
        When: Not specifying use_cache parameter
        Then: Defaults to True (use cache by default)
        """
        sig = inspect.signature(EntityService.get_entity)
        use_cache_param = sig.parameters["use_cache"]

        assert use_cache_param.default is True

    def test_list_entities_default_values(self):
        """
        Test list_entities has sensible defaults.

        Given: EntityService.list_entities method
        When: Examining default values
        Then: Optional parameters default to None (no limits)
        """
        sig = inspect.signature(EntityService.list_entities)

        assert sig.parameters["filters"].default is None
        assert sig.parameters["limit"].default is None
        assert sig.parameters["offset"].default is None
        assert sig.parameters["order_by"].default is None

    def test_relationship_bidirectional_default(self):
        """
        Test add_relationship defaults to unidirectional.

        Given: RelationshipService.add_relationship method
        When: Not specifying bidirectional parameter
        Then: Defaults to False (unidirectional by default)
        """
        sig = inspect.signature(RelationshipService.add_relationship)
        bidirectional_param = sig.parameters["bidirectional"]

        assert bidirectional_param.default is False

    def test_command_validation_defaults(self):
        """
        Test command validate_updates defaults to True.

        Given: UpdateEntityCommand
        When: Not specifying validate_updates
        Then: Defaults to True (validate by default)
        """
        command = UpdateEntityCommand(entity_id="test_id", updates={})

        assert command.validate_updates is True


# =============================================================================
# TYPE HINTS AVAILABILITY TESTS
# =============================================================================


@pytest.mark.usability
class TestTypeHintsAvailability:
    """Test that all public methods have proper type hints."""

    def test_entity_service_has_type_hints(self):
        """
        Test EntityService methods have complete type hints.

        Given: EntityService class
        When: Examining method signatures
        Then: All parameters and return types are annotated
        """
        methods = [
            "create_entity",
            "get_entity",
            "update_entity",
            "delete_entity",
            "list_entities",
            "search_entities",
            "count_entities",
        ]

        for method_name in methods:
            method = getattr(EntityService, method_name)
            hints = get_type_hints(method)

            # Should have return type hint
            assert "return" in hints, f"{method_name} missing return type hint"

            # Check parameter hints (excluding self)
            sig = inspect.signature(method)
            for param_name in sig.parameters:
                if param_name != "self":
                    assert param_name in hints, (
                        f"{method_name} parameter '{param_name}' missing type hint"
                    )

    def test_relationship_service_has_type_hints(self):
        """
        Test RelationshipService methods have complete type hints.

        Given: RelationshipService class
        When: Examining method signatures
        Then: All parameters and return types are annotated
        """
        methods = [
            "add_relationship",
            "remove_relationship",
            "get_relationships",
        ]

        for method_name in methods:
            method = getattr(RelationshipService, method_name)
            hints = get_type_hints(method)

            # Should have return type hint
            assert "return" in hints, f"{method_name} missing return type hint"

    def test_command_classes_have_type_hints(self):
        """
        Test command classes have type hints on attributes.

        Given: Command classes
        When: Examining class attributes
        Then: All attributes have type annotations
        """
        commands = [CreateEntityCommand, UpdateEntityCommand, DeleteEntityCommand]

        for command_class in commands:
            hints = get_type_hints(command_class)
            # Should have type hints for all fields
            assert len(hints) > 0, f"{command_class.__name__} has no type hints"

    def test_entity_model_has_type_hints(self):
        """
        Test Entity models have proper type hints.

        Given: Entity model classes
        When: Examining attributes
        Then: All fields are properly typed
        """
        hints = get_type_hints(Entity)

        # Core fields should be typed
        expected_fields = ["id", "created_at", "updated_at", "status"]
        for field in expected_fields:
            assert field in hints, f"Entity missing type hint for '{field}'"


