@pytest.mark.performance
class TestRelationshipOperationResponseTimes:
    """Test relationship operations meet SLA requirements."""

    def test_add_relationship_response_time(self, mock_repository, mock_logger):
        """
        Test add relationship completes within SLA.

        Given: A relationship service
        When: Adding a relationship
        Then: Operation completes within 150ms
        """
        service = RelationshipService(mock_repository, mock_logger)

        result, duration = measure_execution_time(
            service.add_relationship,
            source_id="entity_1",
            target_id="entity_2",
            relationship_type=RelationType.PARENT_CHILD,
        )

        assert result is not None
        assert_sla_compliance(
            duration, SLALimits.RELATIONSHIP_OPERATION_MAX, "Add relationship"
        )

    def test_remove_relationship_response_time(
        self, mock_repository, mock_logger
    ):
        """
        Test remove relationship completes within SLA.

        Given: An existing relationship
        When: Removing the relationship
        Then: Operation completes within 150ms
        """
        service = RelationshipService(mock_repository, mock_logger)
        relationship = service.add_relationship(
            source_id="entity_1",
            target_id="entity_2",
            relationship_type=RelationType.PARENT_CHILD,
        )

        result, duration = measure_execution_time(
            service.remove_relationship, relationship.id
        )

        assert result is True
        assert_sla_compliance(
            duration, SLALimits.RELATIONSHIP_OPERATION_MAX, "Remove relationship"
        )

    def test_get_relationships_response_time(self, mock_repository, mock_logger):
        """
        Test get relationships completes within SLA.

        Given: 50 relationships in repository
        When: Getting relationships by source
        Then: Operation completes within 150ms
        """
        service = RelationshipService(mock_repository, mock_logger)

        # Create relationships
        for i in range(50):
            rel = Relationship(
                source_id="entity_1",
                target_id=f"entity_{i}",
                relationship_type=RelationType.PARENT_CHILD,
            )
            mock_repository.add_entity(rel)

        result, duration = measure_execution_time(
            service.get_relationships, source_id="entity_1"
        )

        assert len(result) > 0
        assert_sla_compliance(
            duration, SLALimits.RELATIONSHIP_OPERATION_MAX, "Get relationships"
        )

    def test_bidirectional_relationship_response_time(
        self, mock_repository, mock_logger
    ):
        """
        Test bidirectional relationship creation meets SLA.

        Given: A relationship service
        When: Creating bidirectional relationship
        Then: Operation completes within 150ms (includes inverse)
        """
        service = RelationshipService(mock_repository, mock_logger)

        result, duration = measure_execution_time(
            service.add_relationship,
            source_id="entity_1",
            target_id="entity_2",
            relationship_type=RelationType.PARENT_CHILD,
            bidirectional=True,
        )

        assert result is not None
        assert_sla_compliance(
            duration,
            SLALimits.RELATIONSHIP_OPERATION_MAX,
            "Bidirectional relationship",
        )


