{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "app.py"
    },
    {
      "src": "/api/mcp",
      "dest": "app.py"
    },
    {
      "src": "/api/embeddings/process-queue",
      "dest": "app.py"
    },
    {
      "src": "/auth/complete",
      "dest": "app.py"
    },
    {
      "src": "/.well-known/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "ATOMS_FASTMCP_TRANSPORT": "http",
    "ATOMS_FASTMCP_HTTP_PATH": "/api/mcp"
  },
  "crons": [
    {
      "path": "/api/embeddings/process-queue?secret=$CRON_SECRET",
      "schedule": "*/5 * * * *"
    }
  ]
}
