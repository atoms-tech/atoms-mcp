# Atoms MCP Server Configuration

# Supabase Configuration (Database only - uses AuthKit JWTs)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Google Cloud / Vertex AI (for embeddings)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_VERTEX_API_KEY=your-vertex-ai-api-key

# FastMCP Server Configuration
ATOMS_FASTMCP_TRANSPORT=http
ATOMS_FASTMCP_HOST=127.0.0.1
ATOMS_FASTMCP_PORT=8000
ATOMS_FASTMCP_BASE_URL=http://127.0.0.1:8000
ATOMS_FASTMCP_PUBLIC_BASE_URL=https://mcp.atoms.tech

# Authentication Configuration

## WorkOS AuthKit - Required
WORKOS_CLIENT_ID=your-workos-client-id
WORKOS_API_KEY=your-workos-api-key

## OAuth (AuthKit) - Required for public clients
FASTMCP_SERVER_AUTH=fastmcp.server.auth.providers.workos.AuthKitProvider
FASTMCP_SERVER_AUTH_AUTHKITPROVIDER_AUTHKIT_DOMAIN=https://your-authkit-domain.authkit.app
FASTMCP_SERVER_AUTH_AUTHKITPROVIDER_BASE_URL=https://mcp.atoms.tech
FASTMCP_SERVER_AUTH_AUTHKITPROVIDER_REQUIRED_SCOPES=openid,profile,email

## Bearer Token Authentication - Optional for internal services
# Generate with: openssl rand -hex 32
ATOMS_INTERNAL_TOKEN=your-internal-token-here

# Note: AuthKit JWTs from frontend/backend are automatically validated via JWKS

# Rate Limiting
MCP_RATE_LIMIT_RPM=120
MCP_RATE_LIMIT_BACKEND=distributed  # 'distributed' for Redis, 'memory' for in-process

# Upstash Redis (Optional, for distributed caching in production)
# Get these from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
UPSTASH_REDIS_ENABLED=false

# Caching Settings
CACHE_TTL_EMBEDDING=86400        # 24 hours for embeddings
CACHE_TTL_TOKEN=3600             # 1 hour for auth tokens
CACHE_TTL_RESPONSE=3600          # 1 hour for tool responses

# Observability
REDIS_METRICS_ENABLED=true
REDIS_LOG_LEVEL=INFO

# Logging
LOG_LEVEL=INFO

