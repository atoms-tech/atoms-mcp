{
  "name": "atoms-mcp-sst",
  "version": "0.1.0",
  "description": "SST infrastructure for Atoms MCP Server",
  "type": "module",
  "scripts": {
    "dev": "sst dev",
    "deploy": "sst deploy",
    "deploy:prod": "sst deploy --stage production",
    "remove": "sst remove",
    "console": "sst console",
    "typecheck": "tsc --noEmit",
    "test:rls": "python -m pytest tests/unit/security/test_rls_protection.py tests/integration/test_auth_integration.py::TestRLSEnforcement tests/e2e/test_security.py -v"
  },
  "dependencies": {
    "sst": "^3.3.29"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}

