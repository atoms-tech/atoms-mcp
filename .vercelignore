# Vercel ignore file - Exclude everything except what's needed for deployment

# Development and testing
.venv/
__pycache__/
*.pyc
.pytest_cache/
tests/
test_*.py
*.test.py
*_test.py
.env.local
.env.test
*.log

# Documentation
*.md
!README.md
docs/

# Git
.git/
.gitignore

# Build artifacts
dist/
build/
*.egg-info/
htmlcov/

# Large directories not needed for deployment
pheno_vendor/
lib/
src/
# infrastructure/ - NEEDED for deployment! Contains adapters and rate limiter
archive/
examples/

# Development files
requirements-dev.txt
prospector.yaml
sonar-project.properties
pytest.ini
Makefile
*.sh
pyproject.toml

# Images and media
*.png
*.jpg
*.jpeg
*.gif
*.svg

# Old/archived files
*_old.py
*_simplified.py
auth/archived/

# Scripts (not needed at runtime)
scripts/

# Vercel
.vercel/
