def main_async():
    """Async entry point for setuptools"""
    return asyncio.run(main())

def generate_completion():
    """Generate shell completion"""
    import subprocess
    print('Generating shell completion...')
    subprocess.run(['atoms', '--install-completion'], check=True)
    print('Completion installed. Please restart your shell.')

