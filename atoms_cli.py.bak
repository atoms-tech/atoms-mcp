#!/usr/bin/env python3
"""
Atoms.tech CLI - Unified command line interface for atoms.tech operations

Built using pheno-sdk libraries, handles all scripts (backfill, schema handling)
and entry points (deploy TARGET, test TARGET TYPE), with tunneling and process mgmt.

Usage:
    atoms deploy dev|prod
    atoms test TARGET hot|dry|cold
    atoms backfill [--entity-type TYPE] [--limit N] [--dry-run]
    atoms schema [list|analyze|export]
    atoms tunnel start|stop|status
    atoms process start|stop|restart|status
"""

import argparse
import asyncio
import os
import subprocess
import sys
from dataclasses import dataclass
from enum import Enum
from pathlib import Path

# Add pheno-sdk to path
sys.path.insert(0, str(Path(__file__).parent / "pheno-sdk" / "src"))
sys.path.insert(0, str(Path(__file__).parent / "atoms-mcp-prod"))

try:
    from pheno.cli.framework import CommandResult, RichCLI
    from pheno.infra.process_cleanup import ProcessCleanupManager
    from pheno.infra.service_manager import ServiceManager
    from pheno.infra.tunneling import TunnelConfig, TunnelManager, TunnelProtocol, TunnelType, tunnel_registry
    RICH_AVAILABLE = True
except ImportError as e:
    print(f"Warning: pheno-sdk libraries not available: {e}")
    print("Please install pheno-sdk: pip install -e ./pheno-sdk")
    RICH_AVAILABLE = False
    # Fallback CLI
    class RichCLI:
        def __init__(self, name="atoms", version="1.0.0"):
            self.name = name
            self.version = version
        def success(self, msg): print(f"✅ {msg}")
        def error(self, msg): print(f"❌ {msg}")
        def warning(self, msg): print(f"⚠️  {msg}")
        def info(self, msg): print(f"ℹ️  {msg}")
        def header(self, msg): print(f"\n=== {msg} ===\n")

    class CommandResult:
        def __init__(self, success=True, message="", data=None):
            self.success = success
            self.message = message
            self.data = data

try:
    from scripts.backfill_embeddings import EmbeddingBackfiller
    from scripts.mcp_schema_query import MCPSchemaQuery
    BACKFILL_AVAILABLE = True
except ImportError as e:
    print(f"Warning: atoms-mcp-prod scripts not available: {e}")
    BACKFILL_AVAILABLE = False


class DeploymentTarget(str, Enum):
    """Supported deployment targets."""
    DEV = "dev"
    PROD = "prod"


class TestType(str, Enum):
    """Supported test types."""
    HOT = "hot"
    DRY = "dry"
    COLD = "cold"


@dataclass
class DeploymentConfig:
    """Configuration for deployment targets."""
    target: DeploymentTarget
    vercel_command: str
    domain: str
    tunnel_url: str
    env_vars: dict[str, str]


class AtomsCLI:
    """Main CLI class for atoms.tech operations."""

    def __init__(self):
        self.cli = RichCLI(name="atoms", version="1.0.0")
        self.service_manager = None
        self.tunnel_manager = None
        self.process_cleanup = None

        # Load deployment configurations
        self.deployment_configs = {
            DeploymentTarget.DEV: DeploymentConfig(
                target=DeploymentTarget.DEV,
                vercel_command="vercel --prebuilt",
                domain="devmcp.atoms.tech",  # Vercel preview
                tunnel_url="https://atomcp.kooshapari.com",
                env_vars={
                    "ENV": "development",
                    "ATOMS_FASTMCP_TRANSPORT": "http",
                    "ATOMS_FASTMCP_HTTP_PATH": "/api/mcp"
                }
            ),
            DeploymentTarget.PROD: DeploymentConfig(
                target=DeploymentTarget.PROD,
                vercel_command="vercel --prod",
                domain="mcp.atoms.tech",  # Production
                tunnel_url="https://atomcp.kooshapari.com",
                env_vars={
                    "ENV": "production",
                    "ATOMS_FASTMCP_TRANSPORT": "http",
                    "ATOMS_FASTMCP_HTTP_PATH": "/api/mcp",
                    "PRODUCTION": "true"
                }
            )
        }

    def header(self):
        """Display CLI header."""
        self.cli.header("Atoms.tech CLI")

    def success(self, message: str):
        """Display success message."""
        self.cli.success(message)

    def error(self, message: str):
        """Display error message."""
        self.cli.error(message)

    def warning(self, message: str):
        """Display warning message."""
        self.cli.warning(message)

    def info(self, message: str):
        """Display info message."""
        self.cli.info(message)

    async def deploy(self, target: str) -> CommandResult:
        """Deploy to specified target."""
        try:
            deployment_target = DeploymentTarget(target.lower())
        except ValueError:
            return CommandResult(
                success=False,
                message=f"Invalid deployment target: {target}. Use: dev, prod"
            )

        config = self.deployment_configs[deployment_target]

        self.info(f"Deploying to {deployment_target.value}...")
        self.info(f"Domain: {config.domain}")
        self.info(f"Vercel command: {config.vercel_command}")

        try:
            # Change to atoms-mcp-prod directory
            atoms_dir = Path(__file__).parent / "atoms-mcp-prod"
            os.chdir(atoms_dir)

            # Set environment variables
            env = os.environ.copy()
            env.update(config.env_vars)

            # Run vercel deployment
            result = subprocess.run(
                config.vercel_command.split(),
                env=env,
                capture_output=True,
                text=True,
                check=True
            )

            self.success(f"Deployment to {deployment_target.value} completed!")
            self.info(f"Domain: {config.domain}")

            if result.stdout:
                self.info(f"Output: {result.stdout}")

            return CommandResult(
                success=True,
                message=f"Deployed to {deployment_target.value}",
                data={
                    "target": deployment_target.value,
                    "domain": config.domain,
                    "output": result.stdout
                }
            )

        except subprocess.CalledProcessError as e:
            self.error(f"Deployment failed: {e}")
            if e.stderr:
                self.error(f"Error output: {e.stderr}")
            return CommandResult(
                success=False,
                message=f"Deployment failed: {e}"
            )

    async def test(self, target: str, test_type: str) -> CommandResult:
        """Run tests for specified target and type."""
        try:
            test_type_enum = TestType(test_type.lower())
        except ValueError:
            return CommandResult(
                success=False,
                message=f"Invalid test type: {test_type}. Use: hot, dry, cold"
            )

        self.info(f"Running {test_type_enum.value} tests for {target}...")

        try:
            # Change to atoms-mcp-prod directory
            atoms_dir = Path(__file__).parent / "atoms-mcp-prod"
            os.chdir(atoms_dir)

            # Determine test command based on type
            if test_type_enum == TestType.HOT:
                # Hot tests - run against live service
                cmd = ["python", "-m", "pytest", "tests/hot/", "-v"]
                env = os.environ.copy()
                env["TEST_TARGET"] = target
                env["TEST_TYPE"] = "hot"

            elif test_type_enum == TestType.DRY:
                # Dry run - validate without executing
                cmd = ["python", "-m", "pytest", "tests/dry/", "-v", "--dry-run"]
                env = os.environ.copy()
                env["TEST_TARGET"] = target
                env["TEST_TYPE"] = "dry"

            elif test_type_enum == TestType.COLD:
                # Cold tests - full suite with isolated environment
                cmd = ["python", "-m", "pytest", "tests/cold/", "-v"]
                env = os.environ.copy()
                env["TEST_TARGET"] = target
                env["TEST_TYPE"] = "cold"

            # Run tests
            result = subprocess.run(
                cmd,
                env=env,
                capture_output=True,
                text=True,
                check=False  # Don't raise on failure to capture results
            )

            if result.returncode == 0:
                self.success(f"{test_type_enum.value.title()} tests passed for {target}!")
            else:
                self.error(f"{test_type_enum.value.title()} tests failed for {target}")

            if result.stdout:
                self.info(f"Test output:\n{result.stdout}")
            if result.stderr:
                self.warning(f"Test warnings/errors:\n{result.stderr}")

            return CommandResult(
                success=result.returncode == 0,
                message=f"Tests completed with code {result.returncode}",
                data={
                    "target": target,
                    "test_type": test_type_enum.value,
                    "return_code": result.returncode,
                    "stdout": result.stdout,
                    "stderr": result.stderr
                }
            )

        except Exception as e:
            self.error(f"Test execution failed: {e}")
            return CommandResult(
                success=False,
                message=f"Test execution failed: {e}"
            )

    async def backfill(self, entity_type: str | None = None, limit: int | None = None,
                     dry_run: bool = False) -> CommandResult:
        """Run embedding backfill."""
        if not BACKFILL_AVAILABLE:
            return CommandResult(
                success=False,
                message="Backfill scripts not available. Please ensure atoms-mcp-prod is properly set up."
            )

        self.info("Running embedding backfill...")
        if entity_type:
            self.info(f"Entity type: {entity_type}")
        if limit:
            self.info(f"Limit: {limit}")
        if dry_run:
            self.info("Mode: Dry run")

        try:
            # Import and run backfill
            from dotenv import load_dotenv
            from supabase import create_client

            # Load environment
            atoms_dir = Path(__file__).parent / "atoms-mcp-prod"
            os.chdir(atoms_dir)

            load_dotenv(".env")
            load_dotenv(".env.production", override=False)

            # Create Supabase client
            url = os.getenv("SUPABASE_URL")
            key = os.getenv("SUPABASE_SERVICE_ROLE_KEY")

            if not url or not key:
                return CommandResult(
                    success=False,
                    message="Supabase credentials not found in environment"
                )

            supabase = create_client(url, key)
            backfiller = EmbeddingBackfiller(supabase, dry_run=dry_run)

            # Run backfill
            if entity_type and entity_type != "all":
                results = await backfiller.backfill_entity_type(entity_type, limit)
            else:
                results = await backfiller.backfill_all(limit=limit)

            if dry_run:
                self.success("Dry run completed!")
            else:
                self.success("Backfill completed!")

            return CommandResult(
                success=True,
                message="Backfill completed successfully",
                data=results
            )

        except Exception as e:
            self.error(f"Backfill failed: {e}")
            return CommandResult(
                success=False,
                message=f"Backfill failed: {e}"
            )

    async def schema(self, action: str, output_dir: str | None = None) -> CommandResult:
        """Handle schema operations."""
        if not BACKFILL_AVAILABLE:
            return CommandResult(
                success=False,
                message="Schema query scripts not available. Please ensure atoms-mcp-prod is properly set up."
            )

        self.info(f"Running schema operation: {action}")

        try:
            # Change to atoms-mcp-prod directory
            atoms_dir = Path(__file__).parent / "atoms-mcp-prod"
            os.chdir(atoms_dir)

            query = MCPSchemaQuery()

            if action == "list":
                tables = await query.list_tables()
                self.info("Tables:")
                for table in tables:
                    print(f"  - {table.get('table_name', '')}")

            elif action == "analyze":
                metrics = await query.analyze_schema_complexity()
                self.cli.show_table([metrics], "Schema Analysis")

            elif action == "export":
                if not output_dir:
                    output_dir = "schema_docs"
                await query.export_schema_documentation(output_dir)
                self.success(f"Schema documentation exported to {output_dir}")

            else:
                return CommandResult(
                    success=False,
                    message=f"Unknown schema action: {action}. Use: list, analyze, export"
                )

            return CommandResult(
                success=True,
                message=f"Schema {action} completed"
            )

        except Exception as e:
            self.error(f"Schema operation failed: {e}")
            return CommandResult(
                success=False,
                message=f"Schema operation failed: {e}"
            )

    async def tunnel(self, action: str) -> CommandResult:
        """Handle tunnel operations."""
        if not RICH_AVAILABLE:
            return CommandResult(
                success=False,
                message="Tunneling requires pheno-sdk libraries"
            )

        self.info(f"Running tunnel operation: {action}")

        try:
            # Initialize tunnel manager if needed
            if not self.tunnel_manager:
                tunnel_config = {
                    "domain": "atomcp.kooshapari.com",
                    "local_host": "127.0.0.1",
                    "local_port": 8000,
                    "tunnel_type": "cloudflare",
                    "protocol": "https"
                }
                self.tunnel_manager = TunnelManager(tunnel_config)

            if action == "start":
                tunnel_info = await self.tunnel_manager.establish()
                self.success(f"Tunnel started: {tunnel_info.public_url}")

            elif action == "stop":
                await self.tunnel_manager.teardown()
                self.success("Tunnel stopped")

            elif action == "status":
                status = await self.tunnel_manager.status()
                self.info(f"Tunnel status: {status}")

            else:
                return CommandResult(
                    success=False,
                    message=f"Unknown tunnel action: {action}. Use: start, stop, status"
                )

            return CommandResult(
                success=True,
                message=f"Tunnel {action} completed"
            )

        except Exception as e:
            self.error(f"Tunnel operation failed: {e}")
            return CommandResult(
                success=False,
                message=f"Tunnel operation failed: {e}"
            )

    async def process(self, action: str, service: str = "all") -> CommandResult:
        """Handle process management."""
        self.info(f"Running process operation: {action} for {service}")

        try:
            # Initialize process cleanup manager
            if not self.process_cleanup:
                self.process_cleanup = ProcessCleanupManager()

            if action == "start":
                # Start local development server
                self.info("Starting atoms-mcp-prod server...")
                atoms_dir = Path(__file__).parent / "atoms-mcp-prod"
                os.chdir(atoms_dir)

                cmd = [sys.executable, "-m", "atoms_mcp.server"]
                process = subprocess.Popen(cmd, cwd=atoms_dir)
                self.success(f"Server started with PID: {process.pid}")

            elif action == "stop":
                # Stop all atoms-mcp-prod processes
                self.info("Stopping atoms-mcp-prod processes...")
                # This would use process_cleanup.kill_processes_by_pattern
                result = subprocess.run(
                    ["pkill", "-f", "atoms_mcp"],
                    check=False, capture_output=True
                )
                self.success("Processes stopped")

            elif action == "restart":
                await self.process("stop", service)
                await asyncio.sleep(2)
                await self.process("start", service)

            elif action == "status":
                # Check process status
                result = subprocess.run(
                    ["pgrep", "-f", "atoms_mcp"],
                    check=False, capture_output=True
                )
                if result.returncode == 0:
                    pids = result.stdout.decode().strip().split("\n")
                    self.info(f"Running processes: {', '.join(pids)}")
                else:
                    self.info("No atoms-mcp-prod processes running")

            else:
                return CommandResult(
                    success=False,
                    message=f"Unknown process action: {action}. Use: start, stop, restart, status"
                )

            return CommandResult(
                success=True,
                message=f"Process {action} completed"
            )

        except Exception as e:
            self.error(f"Process operation failed: {e}")
            return CommandResult(
                success=False,
                message=f"Process operation failed: {e}"
            )


async def main():
    """Main CLI entry point."""
    parser = argparse.ArgumentParser(
        description="Atoms.tech CLI - Unified command line interface",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__
    )

    parser.add_argument(
        "--version",
        action="version",
        version="atoms 1.0.0"
    )

    # Add completion command
    parser.add_argument(
        '--install-completion',
        action='store_true',
        help='Install shell completion for atoms CLI'
    )
    
    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # Deploy command
    deploy_parser = subparsers.add_parser("deploy", help="Deploy to target environment")
    deploy_parser.add_argument(
        "target",
        choices=["dev", "prod"],
        help="Deployment target"
    )

    # Test command
    test_parser = subparsers.add_parser("test", help="Run tests")
    test_parser.add_argument("target", help="Test target (dev/prod)")
    test_parser.add_argument(
        "test_type",
        choices=["hot", "dry", "cold"],
        help="Test type"
    )

    # Backfill command
    backfill_parser = subparsers.add_parser("backfill", help="Run embedding backfill")
    backfill_parser.add_argument(
        "--entity-type",
        help="Entity type to backfill (organization, project, document, requirement, all)"
    )
    backfill_parser.add_argument(
        "--limit",
        type=int,
        help="Maximum number of entities to process"
    )
    backfill_parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be processed without actually generating embeddings"
    )

    # Schema command
    schema_parser = subparsers.add_parser("schema", help="Schema operations")
    schema_parser.add_argument(
        "action",
        choices=["list", "analyze", "export"],
        help="Schema action"
    )
    schema_parser.add_argument(
        "--output-dir",
        help="Output directory for export"
    )

    # Tunnel command
    tunnel_parser = subparsers.add_parser("tunnel", help="Tunnel operations")
    tunnel_parser.add_argument(
        "action",
        choices=["start", "stop", "status"],
        help="Tunnel action"
    )

    # Process command
    process_parser = subparsers.add_parser("process", help="Process management")
    process_parser.add_argument(
        "action",
        choices=["start", "stop", "restart", "status"],
        help="Process action"
    )
    process_parser.add_argument(
        "--service",
        default="all",
        help="Service to manage (default: all)"
    )

    args = parser.parse_args()
    
    # Handle completion installation
    if args.install_completion:
        install_completion()
        return

    if not args.command:
        parser.print_help()
        return

    # Initialize CLI
    atoms_cli = AtomsCLI()
    atoms_cli.header()

    # Execute command
    try:
        if args.command == "deploy":
            result = await atoms_cli.deploy(args.target)
        elif args.command == "test":
            result = await atoms_cli.test(args.target, args.test_type)
        elif args.command == "backfill":
            result = await atoms_cli.backfill(
                args.entity_type, args.limit, args.dry_run
            )
        elif args.command == "schema":
            result = await atoms_cli.schema(
                args.action, getattr(args, "output_dir", None)
            )
        elif args.command == "tunnel":
            result = await atoms_cli.tunnel(args.action)
        elif args.command == "server":
        from lib.server_manager import handle_server_command
        await handle_server_command(args)
    elif args.command == "process":
            result = await atoms_cli.process(args.action, args.service)
        else:
            atoms_cli.error(f"Unknown command: {args.command}")
            return

        # Display result
        if result.success:
            atoms_cli.success(result.message)
        else:
            atoms_cli.error(result.message)

    except KeyboardInterrupt:
        atoms_cli.warning("Operation cancelled by user")
    except Exception as e:
        atoms_cli.error(f"Unexpected error: {e}")
        import traceback
        traceback.print_exc()


if __name__ == "__main__":
    asyncio.run(main())

def install_completion():
    """Install shell completion for atoms CLI"""
    import os
    
    # Create completion directory
    completion_dir = os.path.expanduser('~/.local/share/bash-completion/completions')
    os.makedirs(completion_dir, exist_ok=True)
    
    # Simple completion script
    completion_script = """#!/bin/bash
# atoms CLI bash completion

_atoms_completion() {
    local cur
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"

    # Command completion
    if [[ ${COMP_CWORD} == 1 ]] ; then
        COMPREPLY=($(compgen -W "deploy test backfill schema tunnel process --version --help" -- ${cur}))
    fi
}

complete -F _atoms_completion atoms
"""
    
    # Install completion script
    completion_dst = os.path.join(completion_dir, 'atoms')
    with open(completion_dst, 'w') as f:
        f.write(completion_script)
    
    print(f'✅ Completion installed to {completion_dst}')
    print('🔄 Please restart your shell or run: source ~/.bashrc')


def main_async():
    """Entry point for setuptools/PyPI installation"""
    return asyncio.run(main())

def generate_completion():
    """Generate shell completion for atoms CLI"""
    try:
        # Try to install completion using typer if available
        try:
            import typer
            # Get completion script
            completion_script = typer.main.get_command_completion(['atoms'])
            print('#!/bin/bash')
            print('# atoms CLI completion')
            print(completion_script)
        except:
            # Fallback to simple completion
            print('#!/bin/bash')
            print('# atoms CLI completion')
            print('_atoms_completion() {')
            print('    local cur prev words')
            print('    COMPREPLY=()')
            print('    cur="${COMP_WORDS[COMP_CWORD]}"')
            print('    prev="${COMP_WORDS[COMP_CWORD-1]}"')
            print('    words="${COMP_WORDS[@]}"')
            print()
            print('    # Command completion')
            print('    if [[ ${cur} == * ]] ; then')
            print('        COMPREPLY=( $(compgen -W "deploy test backfill schema tunnel process --version --help" -- ${cur}) )')
            print('    fi')
            print('}')
            print()
            print('complete -F _atoms_completion atoms')
        
        # Save completion script
        import os
        completion_dir = os.path.expanduser('~/.local/share/bash-completion/completions')
        os.makedirs(completion_dir, exist_ok=True)
        
        with open(f'{completion_dir}/atoms', 'w') as f:
            f.write(completion_script)
            
        print('Completion script installed to ~/.local/share/bash-completion/completions/atoms')
        print('Please restart your shell or run: source ~/.bashrc')
        
    except Exception as e:
        print(f'Error generating completion: {e}')


