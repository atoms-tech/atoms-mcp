# Atoms MCP Server Secrets Configuration
# This file contains sensitive data and should NEVER be committed to version control.
# Copy to .secrets.env and fill in your actual values.
# Add .secrets.env to your .gitignore file.

# ============================================================================
# Supabase Configuration
# ============================================================================
# Get from: https://supabase.com/dashboard/project/_/settings/api
ATOMS_SUPABASE_URL=https://your-project.supabase.co
ATOMS_SUPABASE_ANON_KEY=your_supabase_anon_key_here
ATOMS_SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ============================================================================
# Database Configuration
# ============================================================================
# For PostgreSQL/MySQL (optional - defaults to SQLite)
ATOMS_DATABASE_URL=postgresql://user:password@localhost:5432/atoms

# ============================================================================
# Google AI Platform
# ============================================================================
# Get from: https://console.cloud.google.com/iam-admin/serviceaccounts
ATOMS_GOOGLE_AI_PROJECT=your_google_project_id
ATOMS_GOOGLE_AI_LOCATION=us-central1
ATOMS_GOOGLE_AI_CREDENTIALS="""{
  "type": "service_account",
  "project_id": "your-project-id",
  "private_key_id": "...",
  "private_key": "...",
  "client_email": "...",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token"
}"""

# ============================================================================
# WorkOS Configuration
# ============================================================================
# Get from: https://dashboard.workos.com/
ATOMS_WORKOS_CLIENT_ID=your_workos_client_id
ATOMS_WORKOS_API_KEY=sk_workos_your_api_key_here

# Webhook configuration (optional)
ATOMS_WORKOS_WEBHOOK_SECRET=your_workos_webhook_secret

# ============================================================================
# Authentication
# ============================================================================
# Generate with: openssl rand -hex 32
ATOMS_JWT_SECRET=your_jwt_secret_here
ATOMS_SESSION_SECRET=your_session_secret_here

# ============================================================================
# External Services
# ============================================================================
# Webhook signature (generate with: openssl rand -hex 32)
ATOMS_WEBHOOK_SECRET=your_webhook_secret_here
